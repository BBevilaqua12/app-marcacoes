.env
*.env
.env.*
!.env.example
serviceAccountKey.json
firebase-*.json
**/serviceAccountKey.json

# ======================== PYTHON ========================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.Python

# Ambientes virtuais
venv/
venv_*/
.venv/
env/
ENV/

# ======================== NODE.JS ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
package-lock.json
yarn.lock

# ======================== BAILEYS / WHATSAPP ========================
# Sessão do WhatsApp (credenciais de sessão sensíveis)
sessao_whatsapp/
**/sessao_whatsapp/

# ======================== EDITORES E SISTEMA ========================
# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.nfs*

