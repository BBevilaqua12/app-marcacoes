# ============================================================================
# 🔐 VARIÁVEIS DE AMBIENTE — bot-whatsapp
# ============================================================================
# Copie este arquivo para ".env" e preencha com seus valores reais.
# O arquivo .env é IGNORADO pelo .gitignore e NUNCA deve ser commitado.
# ============================================================================

# Número da dona do salão (com DDI 55, sem +)
NUMERO_DONA=55XXXXXXXXXXX

# URL da API Flask (Render em produção, localhost em dev)
# Em dev local:  http://localhost:5000
# Em produção:   https://seu-app.onrender.com
FLASK_API_URL=http://localhost:5000

# Porta do servidor Express do bot
PORTA=3001
